{
	"name": "kids-team",
	"version": "2.1.3",
	"description": "Theme for kids-team Website",
	"prettier": "@wordpress/prettier-config",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build src/theme.js src/admin.js",
		"start": "wp-scripts start src/theme.js src/admin.js",
		"make-pot": "wp i18n make-pot . languages/kids-team.pot --slug=kids-team --domain=kids-team --exclude=node_modules,src",
		"make-json": "wp i18n make-json languages/ --no-purge",
		"release": "wp-github-plugin style.css --tag",
		"packages-update": "wp-scripts packages-update"
	},
	"license": "GPL",
	"author": {
		"name": "kids-team Österreich",
		"email": "thomas@kids-team.at"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@types/wordpress__block-editor": "^15.0.3",
		"@types/wordpress__blocks": "^15.10.0",
		"@types/wordpress__data": "^6.0.2",
		"@types/wordpress__editor": "^14.3.1",
		"@wordpress/scripts": "^31.8.0"
	}
}
